<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    
    <bean class="com.beans.Address" id="AddrId">
    
   		<property name="houseno" value="34"/>
    	<property name="city" value="Pune"/>
    	<property name="pincode" value="410504"/>
    
    
    </bean>
    
    <bean class="com.beans.Student" id="StdId">
    
    	<property name="id" value="101"/>
    	<property name="name" value="Nitin"/>
    	<property name="address" ref="AddrId"/>
    
    </bean>

</beans>